{
  "$schema": "https://json.schemastore.org/package.json",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently -k -n VITE,LINT -c \"blue,green\" \"npm run watch\" \"npm run watch:lint\"",
    "watch": "vite build --watch",
    "lint:scss": "stylelint --config .stylelintrc.json 'public/themes/zeze-bizou/app/scss/**/*.scss'",
    "lint:js": "biome check",
    "fix:scss": "stylelint --fix --config .stylelintrc.json 'public/themes/zeze-bizou/app/scss/**/*.scss'",
    "fix:js": "biome check --write --unsafe",
    "watch:lint": "chokidar 'public/themes/zeze-bizou/app/**/*.{js,scss}' -c 'npm run lint:js && npm run fix:scss'"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "vite": "^7.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "bootstrap": "^5.3.8",
    "chokidar-cli": "^3.0.0",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.0.0"
  }
}
